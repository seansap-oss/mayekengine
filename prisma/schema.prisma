generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PartOfSpeech {
  Noun
  Verb
  Adjective
  Pronoun
  Adverb
  Particle
  Phrase
}

enum VerificationStatus {
  Verified
  Pending
  Rejected
}

model WordEntry {
  id                 String             @id @default(uuid())
  standardRoman      String             @unique
  meiteiMayek        String
  bengaliScript      String?
  englishTranslation String
  partOfSpeech       PartOfSpeech
  verificationStatus VerificationStatus
  upvotes            Int                @default(0)
  downvotes          Int                @default(0)
  variants           PhoneticVariant[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
}

model PhoneticVariant {
  id             String    @id @default(uuid())
  wordId         String
  word           WordEntry @relation(fields: [wordId], references: [id])
  variant        String
  frequencyScore Int       @default(0)
}

model APIKey {
  id        String @id @default(uuid())
  key       String @unique
  ownerName String
  rateLimit Int    @default(100)
}
